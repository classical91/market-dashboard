# Market Dashboard environment template
# Copy to .env for local development. Leave optional keys blank to use built-in fallbacks.

# Server
PORT=3000
DATA_DIR=./data

# Admin key guarding action/mutation endpoints (report + AI-analysis generate,
# Telegram broadcast/test/diagnose, log import, and the detailed health probe).
# REQUIRED to enable those actions: while this is blank the server returns 503
# for them. In the browser, open a protected page (Reporter, AI Analysis,
# Settings) and enter this value when prompted — it is stored locally and sent
# as the x-admin-key header. Read-only views stay public.
ADMIN_API_KEY=

# OpenAI reporter endpoint (/reporter.html and /api/daily-report)
OPENAI_API_KEY=
REPORTER_MODEL=gpt-5.4-mini

# Telegram reporter delivery (also used by the AI Analysis broadcast button)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids. To target a specific forum "topic" thread inside a
# group instead of its general chat, append :threadId, e.g.:
# TELEGRAM_CHAT_IDS=-1001841650798:6297,-1001941064823:984
TELEGRAM_CHAT_IDS=

# AI Analysis (/ai-analysis.html and /api/ai-analysis) — renders a TradingView
# chart via chart-img.com, then sends it to an OpenAI vision model for a
# BUY/SELL/HOLD read. Reuses OPENAI_API_KEY above.
CHART_IMG_API_KEY=
CHART_IMG_BASE_URL=https://api.chart-img.com/v2/tradingview/advanced-chart/storage
AI_ANALYSIS_MODEL=gpt-5.4-mini
AI_ANALYSIS_CACHE_MS=1800000
# Optional JSON array to override the default crypto + BTC-correlated macro 4h presets, e.g.:
# AI_ANALYSIS_SYMBOLS=[{"symbol":"BINANCE:BTCUSDT","label":"BTCUSDT","interval":"4h"}]
AI_ANALYSIS_SYMBOLS=

# Overview API (/api/overview)
OVERVIEW_CACHE_MS=60000
MARKET_DATA_PROVIDER=coingecko
MARKET_DATA_API_KEY=
MARKET_DATA_BASE_URL=https://api.coingecko.com/api/v3
MARKET_DATA_TIMEOUT_MS=8000
MARKET_DATA_RETRIES=1

# CoinGecko keys are optional. Anonymous public data is used when blank.
COINGECKO_DEMO_API_KEY=
COINGECKO_API_KEY=
COINGECKO_KEY_HEADER=

# Live equities through Finnhub. Without this, equities fall back to static values.
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# X Intelligence (/x-intelligence.html). Uses the official X API when set,
# otherwise falls back to the public syndication endpoint.
X_API_BEARER_TOKEN=

# Optional JSON news feed URL. Without this, news falls back to static headlines.
MARKET_NEWS_URL=

# DefiLlama on-chain / stablecoin data
DEFILLAMA_API_BASE_URL=https://stablecoins.llama.fi/
DEFILLAMA_COINS_API_BASE_URL=https://coins.llama.fi/
DEFILLAMA_CHAIN=Ethereum
DEFILLAMA_COIN_CHAIN=ethereum

# Etherscan wallet detail API
ETHERSCAN_API_KEY=
ETHERSCAN_KEY=
ETHERSCAN_API_BASE_URL=https://api.etherscan.io
ETHERSCAN_CHAIN_ID=1
ETHERSCAN_API_REQUEST_TIMEOUT_MS=15000
ETHERSCAN_API_RETRIES=2

# Covalent transfer analytics API
COVALENT_API_KEY=
COVALENT_KEY=
COVALENT_API_BASE_URL=https://api.covalenthq.com
COVALENT_CHAIN_NAME=eth-mainnet
COVALENT_API_REQUEST_TIMEOUT_MS=15000
COVALENT_API_RETRIES=2
COVALENT_CREDIT_COOLDOWN_MS=1800000
COVALENT_RATELIMIT_COOLDOWN_MS=120000

# On-chain analytics tuning
ONCHAIN_TRACKED_TOKENS=[{"symbol":"USDC","name":"USD Coin","contractAddress":"0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48","decimals":6},{"symbol":"USDT","name":"Tether USD","contractAddress":"0xdac17f958d2ee523a2206206994597c13d831ec7","decimals":6}]
ONCHAIN_IGNORED_ADDRESSES=
ONCHAIN_OVERVIEW_CACHE_MS=180000
ONCHAIN_DETAIL_CACHE_MS=60000
ONCHAIN_OVERVIEW_LOOKBACK_HOURS=24
ONCHAIN_DETAIL_LOOKBACK_DAYS=7
ONCHAIN_OVERVIEW_PAGE_SIZE=100
ONCHAIN_DETAIL_PAGE_SIZE=100
ONCHAIN_OVERVIEW_PAGE_LIMIT=2
ONCHAIN_TOKEN_PAGE_LIMIT=2
ONCHAIN_MAX_LARGE_TRANSFERS=25
ONCHAIN_MAX_WALLET_ROWS=10
ONCHAIN_MAX_TOKEN_ROWS=10
ONCHAIN_MAX_DETAIL_TRANSFERS=25
ONCHAIN_LARGE_TRANSFER_THRESHOLD_USD=100000
ONCHAIN_WHALE_THRESHOLD_USD=100000
