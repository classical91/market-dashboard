OPENAI_API_KEY=your_openai_api_key_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_IDS=-100123456789,-100987654321
DUNE_API_KEY=your_dune_api_key_here
DUNE_API_BASE_URL=https://api.dune.com/api/v1
DUNE_API_REQUEST_TIMEOUT_MS=15000
DUNE_API_RETRIES=2
DUNE_POLL_INTERVAL_MS=1500
DUNE_EXECUTION_TIMEOUT_MS=45000
DUNE_RESULT_LIMIT=100
DUNE_PERFORMANCE=medium
ONCHAIN_OVERVIEW_CACHE_MS=180000
ONCHAIN_DETAIL_CACHE_MS=60000

# Overview API (/api/overview)
OVERVIEW_CACHE_MS=60000
# Crypto data uses CoinGecko by default (no key required, free public tier)
MARKET_DATA_PROVIDER=coingecko
MARKET_DATA_API_KEY=
MARKET_DATA_BASE_URL=https://api.coingecko.com/api/v3
MARKET_DATA_TIMEOUT_MS=8000
MARKET_DATA_RETRIES=1
# CoinGecko demo key (free, ~3x higher rate-limit than anonymous public tier)
# Sign up at https://www.coingecko.com/en/api/pricing -> "Demo" plan.
# If set, sent as `x-cg-demo-api-key`. Use COINGECKO_API_KEY for paid plans
# (sent as `x-cg-pro-api-key`). Override the header name via COINGECKO_KEY_HEADER.
COINGECKO_DEMO_API_KEY=
COINGECKO_API_KEY=
COINGECKO_KEY_HEADER=
# Live equity quotes via Finnhub (https://finnhub.io). Free tier: 60 req/min.
# Without this key, the four equities (SPY/QQQ/NVDA/TSLA) fall back to static values.
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
# Optional: news endpoint that returns { items: [{ title, source, url, publishedAt }] }
MARKET_NEWS_URL=
DUNE_PARAM_WALLET_ADDRESS=address
DUNE_PARAM_TOKEN_ADDRESS=address

# Overview queries
DUNE_Q_STABLECOIN_NETFLOW=0
DUNE_Q_TOP_INFLOWS=0
DUNE_Q_TOP_OUTFLOWS=0
DUNE_Q_ACCUMULATED_TOKENS=0
DUNE_Q_DISTRIBUTED_TOKENS=0
DUNE_Q_LARGE_TRANSFERS=0

# Detail queries
DUNE_Q_WALLET_SUMMARY=0
DUNE_Q_WALLET_TRANSFERS=0
DUNE_Q_TOKEN_SUMMARY=0
DUNE_Q_TOKEN_WHALES=0
